{
  "name": "trusted-publish",
  "version": "0.0.0",
  "description": "CLI to configure npm trusted publishers for single and monorepo packages",
  "keywords": [
    "circleci",
    "cli",
    "github-actions",
    "gitlab-ci",
    "monorepo",
    "npm",
    "oidc",
    "trusted-publisher",
    "trusted-publishers",
    "workspace"
  ],
  "homepage": "https://github.com/ntnyq/trusted-publish#readme",
  "bugs": {
    "url": "https://github.com/ntnyq/trusted-publish/issues"
  },
  "license": "MIT",
  "author": {
    "name": "ntnyq",
    "email": "ntnyq13@gmail.com"
  },
  "repository": "ntnyq/trusted-publish",
  "bin": {
    "trusted-publish": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./cli": {
      "types": "./dist/cli.d.mts",
      "default": "./dist/cli.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "cli": "node ./dist/cli.mjs",
    "cli:dry-run": "node ./dist/cli.mjs setup --dry-run",
    "cli:verify": "node ./dist/cli.mjs verify",
    "dev": "tsdown --watch",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build",
    "release": "run-s release:check release:version",
    "release:check": "run-s format:check lint typecheck test",
    "release:version": "bumpp",
    "test": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "cac": "^7.0.0",
    "consola": "^3.4.2",
    "tinyglobby": "^0.2.17",
    "unconfig": "^7.5.0"
  },
  "devDependencies": {
    "@ntnyq/tsconfig": "^3.1.0",
    "@types/node": "^25.9.3",
    "@typescript/native-preview": "^7.0.0-dev.20260614.1",
    "bumpp": "^11.1.0",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "tsdown": "^0.22.2",
    "tsnapi": "^0.3.3",
    "vitest": "^4.1.8"
  },
  "nano-staged": {
    "*.{js,ts,mjs,tsx}": "oxlint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@11.6.0"
}
